	<string>This app needs camera access to scan barcodes for billing.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>This app needs photo library access to select images for products or customers.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>This app needs permission to save generated PDFs to your photo library.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>This app needs microphone access if you record videos for bug reports.</string>
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>This app needs Bluetooth access to connect to thermal printers for billing.</string>
	<key>NSBluetoothPeripheralUsageDescription</key>
	<string>This app needs Bluetooth access to connect to thermal printers for billing.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>This app needs location access to scan for nearby Bluetooth printers.</string>
	<key>NSFaceIDUsageDescription</key>
	<string>This app needs Face ID access for secure login.</string>
	<key>UIAppFonts</key>
	<array>
		<string>Outfit-Regular.ttf</string>
		<string>Outfit-Medium.ttf</string>
		<string>Outfit-SemiBold.ttf</string>
		<string>Outfit-Bold.ttf</string>
	</array>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
</dict>
